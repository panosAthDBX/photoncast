<?xml version="1.0" encoding="utf-8"?>
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" version="2.0">
    <channel>
        <title>PhotonCast Changelog</title>
        <link>https://api.photoncast.app/updates/appcast.xml</link>
        <description>Appcast feed for PhotonCast auto-updates</description>
        <language>en</language>
        <lastBuildDate>{{BUILD_DATE}}</lastBuildDate>

        <item>
            <title>PhotonCast {{VERSION}}</title>
            <pubDate>{{PUB_DATE}}</pubDate>
            <sparkle:version>{{BUILD_NUMBER}}</sparkle:version>
            <sparkle:shortVersionString>{{VERSION}}</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>12.0</sparkle:minimumSystemVersion>

            <description><![CDATA[
                <h2>What's New in PhotonCast {{VERSION}}</h2>
                <p>{{RELEASE_NOTES}}</p>
                <hr>
                <p>For full release notes, visit <a href="https://github.com/photoncast/photoncast/releases/tag/v{{VERSION}}">GitHub Releases</a>.</p>
            ]]></description>

            <enclosure
                url="{{DMG_URL}}"
                sparkle:edSignature="{{ED_SIGNATURE}}"
                length="{{DMG_SIZE}}"
                type="application/octet-stream"
            />
        </item>
    </channel>
</rss>
